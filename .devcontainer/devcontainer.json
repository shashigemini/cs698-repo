{
    "name": "cs698_dev_container",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "features": {
        "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
            "version": "latest",
            "enableNonRootDocker": "true",
            "moby": "true"
        },
        "ghcr.io/devcontainers/features/node:1": {
            "version": "lts",
            "pnpmVersion": "latest"
        }
    },
    "containerEnv": {
        "DISPLAY": ":0",
        "WAYLAND_DISPLAY": "wayland-0",
        "XDG_RUNTIME_DIR": "/mnt/wslg/runtime-dir",
        "PULSE_SERVER": "/mnt/wslg/PulseServer"
    },
    "customizations": {
        "vscode": {
            "settings": {
                "python.defaultInterpreterPath": "/workspaces/cs698-repo/backend/.venv/bin/python",
                "python.testing.pytestEnabled": true,
                "python.testing.pytestArgs": [
                    "backend/tests"
                ],
                "python.locator": "js",
                "python.languageServer": "None"
            },
            "extensions": [
                "ms-python.python",
                "meta.pyrefly",
                "charliermarsh.ruff",
                "tamasfe.even-better-toml",
                "ms-azuretools.vscode-docker",
                "dart-code.dart-code",
                "dart-code.flutter",
                "github.vscode-github-actions"
            ]
        }
    },
    "forwardPorts": [
        8000
    ],
    "runArgs": [
        "--add-host=host.docker.internal:host-gateway"
    ],
    "postCreateCommand": "cp -n backend/.env.example backend/.env && cd backend && poetry install --with dev && cd ../frontend && flutter pub get",
    "postStartCommand": "mkdir -p /home/vscode/.gemini/antigravity && rm -f /home/vscode/.gemini/antigravity/mcp_config.json && ln -s /workspaces/${localWorkspaceFolderBasename}/.gemini/settings.json /home/vscode/.gemini/antigravity/mcp_config.json && /workspaces/${localWorkspaceFolderBasename}/.devcontainer/proxy_backend.sh",
    "remoteUser": "vscode"
}