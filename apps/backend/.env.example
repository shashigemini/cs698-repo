# Environment: development | staging | production
ENVIRONMENT=development
DEBUG=true

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/spiritual_qa
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT (RS256) ---
# Option 1: Inline PEM strings
# JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
#
# Option 2: File paths (prefix with @)
# JWT_PRIVATE_KEY=@/path/to/private.pem
# JWT_PUBLIC_KEY=@/path/to/public.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=7

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# --- Rate Limiting ---
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MINUTES=15
RATE_LIMIT_REGISTER_MAX=3
RATE_LIMIT_REGISTER_WINDOW_MINUTES=60
RATE_LIMIT_GUEST_QUERY_MAX=10
RATE_LIMIT_GUEST_QUERY_WINDOW_HOURS=24
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_GLOBAL_WINDOW_SECONDS=60

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# --- Qdrant ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=spiritual_docs

# --- Security ---
CSRF_SECRET=change-me-in-production-generate-with-openssl-rand-hex-32
MAX_REQUEST_BODY_BYTES=1048576
MAX_QUERY_LENGTH=2000

# --- PDF Storage ---
PDF_STORAGE_PATH=./data/pdfs
