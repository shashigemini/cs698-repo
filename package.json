  "version": "1.0.0",
  "description": "Spiritual Q&A Platform monorepo with Flutter frontend, FastAPI backend, Terraform infra, and Docusaurus docs.",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "backend:test": "cd apps/backend && poetry run pytest -v",
